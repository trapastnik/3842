.DS_Store
Thumbs.db
.claude/
~$*
*.tmp
*.swp
*.swo

# Python tooling artefacts (например, в assets/mtkXX/tools/)
__pycache__/
*.pyc

# Скриншоты / превью / временные изображения — заблокированы по умолчанию,
# чтобы случайные снимки рабочей среды не попадали в репо.
# Контентные ассеты живут в assets/mtkXX/ — там разрешены через исключение ниже.
*.png
*.jpg
*.jpeg
*.gif
*.webp

# Контент: per-МТК ассеты (изображения, аудио, маленькое видео) разрешены.
# Структура — см. COORDINATION.md → «Границы файлов» и «Контент-политика».
!assets/**

# МТК content images live in repo (museum installation needs offline data)
!data/images/**

# Manual snapshots are local only; git history is the versioning layer.
versions/
